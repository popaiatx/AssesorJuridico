# =============================================================================
# .env.example — documenta TODAS as variáveis. SEM valores reais.
# Copie para .env e preencha localmente. NUNCA commite o .env (ver .gitignore).
# Segredos vivem em secret manager / variáveis de ambiente, jamais no código.
# =============================================================================

# --- Servidor HTTP ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Nível de log: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Supabase (projeto) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Chave pública (pode ir ao cliente; só é segura porque o RLS limita o que enxerga).
SUPABASE_ANON_KEY=

# --- service_role: ISOLADA. IGNORA O RLS. ---
# Uso EXCLUSIVO de back-office / migrações / jobs administrativos.
# NUNCA no caminho de um assinante. Ver src/infra/db/admin.ts e CLAUDE.md.
SUPABASE_SERVICE_ROLE_KEY=

# --- Banco de dados (caminho da aplicação / tenant) ---
# Conexão via POOLER do Supabase (Supavisor) em MODO TRANSACTION (porta 6543).
# IMPORTANTE: a role desta string NÃO pode ser superuser nem ter BYPASSRLS,
# senão o RLS é ignorado. Ver README (seção "RLS e a role de conexão").
# Ex.: postgresql://USER.PROJECT-ref:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# =============================================================================
# Adapters externos — PENDENTE (stubs nesta fase; ainda não usados).
# Preencher quando cada adapter for implementado nas próximas fases.
# =============================================================================

# --- WhatsApp (Cloud API / BSP) — PENDENTE ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Pagamento (default Asaas) — PENDENTE ---
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# --- Tribunais (agregador: Judit/Escavador/Codilo/Digesto) — PENDENTE ---
COURTS_API_KEY=
COURTS_WEBHOOK_SECRET=

# --- LLM (provedor com política de não-treinamento + DPA) — PENDENTE ---
LLM_API_KEY=
