# =============================================================================
# .env.example — FONTE ÚNICA de configuração (ver CLAUDE.md › Configuração e
# repositório). Copie para .env e preencha. NUNCA commite o .env (.gitignore).
# Segredos vivem em secret manager / variáveis de ambiente, jamais no código.
#
# Convenção: a validação (Zod, src/infra/config) exige em fail-fast SÓ o que já
# está implementado. As variáveis de etapas futuras ficam OPCIONAIS e só são
# exigidas quando o adapter correspondente for ativado. Cada bloco indica
# [EM USO] ou a etapa em que passa a ser necessário.
# =============================================================================

# --- App [EM USO] ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Nível de log: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Supabase [EM USO] ---
# Projeto Supabase. URL e anon key: painel > Project Settings > API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role: ADMIN ONLY. IGNORA O RLS — só back-office/migrações, NUNCA no
# caminho de um assinante (ver src/infra/db/admin.ts e CLAUDE.md).
SUPABASE_SERVICE_ROLE_KEY=
# Conexão da aplicação via POOLER (Supavisor) em MODO TRANSACTION (porta 6543).
# A role NÃO pode ser superuser nem ter BYPASSRLS, senão o RLS é ignorado
# (ver README › "RLS e a role de conexão"). Painel > Database > Connection pooling.
# Ex.: postgresql://USER.PROJECT-ref:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- WhatsApp Cloud API [etapa: adapter WhatsApp] ---
# Meta for Developers > seu app > WhatsApp > API Setup.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Token que você define e a Meta ecoa no handshake de verificação do webhook.
WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta > Configurações > Básico) — valida a assinatura do webhook.
WHATSAPP_APP_SECRET=

# --- Pagamento Asaas [EM USO quando preenchido] ---
# Ambiente: sandbox (testes, sem dinheiro real) | production. Default: sandbox.
# Define a URL base oficial da API v3 (sandbox: api-sandbox.asaas.com; prod: api.asaas.com).
ASAAS_ENV=sandbox
# Chave de API do Asaas. Sandbox: painel sandbox > Configurações > Integrações >
# Chave de API (sandbox começa com $aact_hmlg_). NUNCA commitar.
ASAAS_API_KEY=
# Token de autenticação do webhook: string que VOCÊ define e cola no painel do
# Asaas (vira o header `asaas-access-token`); precisa ser IDÊNTICA aqui.
ASAAS_WEBHOOK_SECRET=

# --- Tribunais / agregador (Cérebro 3) [etapa: integração tribunais] ---
# Chave do agregador escolhido (Judit/Escavador/Codilo/Digesto).
COURTS_API_KEY=
COURTS_WEBHOOK_SECRET=

# --- LLM [EM USO em dev: classificação de intenção + ajuda/conversa geral] ---
# Provider-agnostic. Trocar de provedor/modelo é só mudar estas variáveis.
# IMPORTANTE: use um provedor com POLÍTICA DE NÃO-TREINAMENTO sobre os dados +
# DPA (Anthropic e OpenAI, no tier de API, não treinam por padrão — confirme o DPA
# antes de produção). Nunca envie dado de cliente identificável sem anonimizar.
# Provedor: anthropic | openai
LLM_PROVIDER=
# Modelo. Recomendado em dev: claude-haiku-4-5 (barato/rápido) com provider anthropic.
# Para o RAG jurídico (futuro), usar um modelo mais forte (ex.: claude-opus-4-8).
# Com provider openai, preencha com o modelo desejado do provedor.
LLM_MODEL=
# Chave de API do provedor escolhido (Anthropic Console ou OpenAI Platform).
LLM_API_KEY=

# --- Embeddings [necessário para o Cérebro 2 (RAG jurídico)] ---
# Provedor próprio (a Anthropic não tem embeddings). Sem isto, o RAG fica inativo
# e duvida_juridica segue placeholder. Provedor: openai
EMBEDDINGS_PROVIDER=
# Recomendado: text-embedding-3-small (1536 dims; barato). Trocar o modelo/dim
# exige reingerir o corpus (a coluna é vector(1536)).
EMBEDDINGS_MODEL=
# Chave de API do provedor de embeddings (ex.: OpenAI Platform).
EMBEDDINGS_API_KEY=
# Limiar mínimo de similaridade (0–1) para um trecho ser "fonte" de afirmação no
# RAG. Mais alto = mais conservador (recusa mais). Default 0.3.
RAG_MIN_SIMILARITY=0.3
# Quantos trechos a busca recupera por pergunta (top-k). Mais alto = menos chance de
# perder o artigo certo, com mais ruído/tokens. Ajustável sem reingerir. Default 8.
RAG_TOP_K=8

# --- Memória de conversa (Cérebro / Passo 9) [EM USO] ---
# Mantém o FIO do assunto entre mensagens (resolve "dela", "o artigo seguinte").
# Guarda só intenção + citações públicas por assinante (sem PII); NUNCA é fonte de
# afirmação jurídica. Liga/desliga sem remover código (default ligado).
CONVERSA_MEMORIA_ENABLED=true
# Tamanho da janela (mensagens guardadas por assinante). Default 6 (~3 pares).
CONVERSA_MEMORIA_TURNOS=6
# Expiração por silêncio (min): após esse tempo sem mensagem, a memória "esfria".
CONVERSA_MEMORIA_TTL_MIN=30

# --- Lembrete proativo (Passo 10) [operacional] ---
# Job SEPARADO do web server (Railway Cron a cada 15 min): npm run send:lembretes.
# Avisa o advogado antes de audiências/prazos (24h e 1h antes — já gravados pelo
# Cérebro 1). Mensagem PROATIVA → vai por TEMPLATE aprovado (lembrete_generico).
# Liga/desliga sem remover o agendamento (default ligado).
LEMBRETES_ENABLED=true
# Janela de recuperação (min): dispara lembretes vencidos até este tempo atrás
# (recupera de janelas de downtime do cron, sem disparar antigos). Default 60.
LEMBRETES_GRACE_MIN=60
# Fuso para EXIBIR a hora no texto ("amanhã às 14:00"); a comparação é em UTC.
LEMBRETES_TIMEZONE=America/Sao_Paulo
# Lembrete de COBRANÇA (Passo 16): aviso ao PRÓPRIO advogado de parcela de
# honorário vencendo (o sistema NUNCA cobra o cliente final). Roda no MESMO job.
# Dias antes do vencimento para avisar (lista separada por vírgula).
# "0" = só no dia do vencimento (default). Ex.: "3,0" = 3 dias antes E no dia.
COBRANCA_LEMBRETE_DIAS_ANTES=0
# Horário local (Brasília) do aviso de cobrança, HH:MM. Default 09:00.
COBRANCA_LEMBRETE_HORA=09:00

# --- Documentos (Passo 12A) [EM USO quando há LLM + Storage] ---
# Arquivos vão para um BUCKET PRIVADO do Supabase Storage (crie um bucket com este
# nome, privado, no painel). O acesso ao ARQUIVO usa a SUPABASE_SERVICE_ROLE_KEY; o
# isolamento é garantido pela tabela `documentos` (RLS) + caminho ${assinante}/${id}/.
DOCUMENTOS_BUCKET=documentos
# Validade (segundos) das URLs assinadas de download (curta, por sigilo).
DOCUMENTOS_URL_TTL_SEC=300
# Tamanho máximo aceito por documento (MB).
DOCUMENTOS_MAX_MB=20

# --- Busca de documentos (Passo 12B) [EM USO quando há Storage] ---
# A busca combina EXATA (texto/número) + SEMÂNTICA (significado, exige EMBEDDINGS_*).
# Sem embeddings, funciona só a exata. Ambas escopadas por assinante (RLS backstop).
# Quantos resultados devolver (exata + semântica combinadas).
DOCUMENTOS_BUSCA_TOPN=5
# Piso de similaridade (0..1) da busca semântica — abaixo disso o vizinho é
# considerado irrelevante e não entra (evita devolver "qualquer coisa parecida").
DOCUMENTOS_BUSCA_MIN_SIM=0.3

# --- OCR local (Passo 13) [EM USO; documento NUNCA sai do ambiente] ---
# Quando a extração nativa falha (PDF escaneado, foto), tenta OCR LOCAL (tesseract.js,
# WASM) para tirar o documento do "ponto cego". O modelo de idioma é vendorizado
# (vendor/tessdata) — sem download em runtime. Sem dependência de sistema no Railway.
# Liga/desliga (false = escaneado continua sem_texto, como antes do Passo 13).
OCR_ENABLED=true
# Idioma do OCR (precisa de vendor/tessdata/<idioma>.traineddata.gz). 'por' = português.
OCR_IDIOMA=por
# Confiança mínima (0–100) para ACEITAR o OCR. Abaixo disso, NÃO indexa (não inventa):
# melhor o documento ficar fora da busca do que registrar um número lido errado.
OCR_MIN_CONFIANCA=60
# Teto de páginas no OCR SÍNCRONO (fluxo da conversa). PDF maior é lido só nas
# primeiras N páginas, com aviso. Para o documento inteiro (offline), use `doc:ocr`.
OCR_MAX_PAGINAS=3
# Pasta dos modelos vendorizados (relativa à raiz do projeto).
OCR_TESSDATA_DIR=vendor/tessdata

# --- Sincronização do corpus (Cérebro 2 / Passo 8B) [operacional] ---
# Mantém o corpus local fresco a partir da fonte oficial (Planalto). O sync é um
# JOB SEPARADO do web server: `npm run sync:corpus` (ver README › Sincronização).
# Liga/desliga o sync sem remover o agendamento. Default: ligado (qualquer valor
# != "false"). Use "false" para pausar.
CORPUS_SYNC_ENABLED=true
# Cadência do Railway Cron Job (apenas DOCUMENTAÇÃO desta variável — quem agenda é o
# Railway). Recomendado: semanal. Ex.: "0 4 * * 1" (toda segunda, 04:00 UTC).
CORPUS_SYNC_CRON=0 4 * * 1
